# Copy this file to .env and fill in your credentials. DO NOT commit secrets.

# Choose 'sandbox' for testing or 'production' for live calls
SQUARE_ENV=sandbox

# Sandbox token (example placeholder)
SQUARE_SANDBOX_ACCESS_TOKEN=replace_with_sandbox_token

# Production token (live) - do not set while testing
SQUARE_ACCESS_TOKEN=replace_with_production_token

# Perplexity API key (if required by your Perplexity installation)
PERPLEXITY_API_KEY=replace_with_perplexity_api_key

# Comet ML API key (for experiment logging)
COMET_API_KEY=replace_with_comet_api_key

# Optional: set to 'true' to actually POST payments; by default sample code will not create real payments
DRY_RUN=true

# Google Sheets -> Notion questionnaire mirror
# Primary central sheet (Dashboard - CentralTFC) from your saved system map
GOOGLE_SHEETS_SPREADSHEET_ID=1x5I9-qOCjEER3gIHnX2Ds-C-xhdo92hQTX0vpeohLHY
GOOGLE_SHEETS_WORKSHEET=Questionnaire Responses
# Secondary sheet used for check-ins/recalibration
GOOGLE_SHEETS_CHECKINS_SPREADSHEET_ID=1-D1MCAJYb6rqZ3gmGHqB_q2FCEs74paAQ4MTsi06MhU
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
# Alternative to file path, set full JSON string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Notion settings for creating a new mirror database
NOTION_TOKEN=secret_notion_token_here
NOTION_PARENT_PAGE_ID=replace_with_notion_parent_page_id

# Optional Notion config IDs extracted from your saved prompt and database list
# Keep these as config references (not secrets)
NOTION_DB_OFFICIAL_DATABASE_ID=28072568-b32a-802c-ac78-faac010d4577
NOTION_DB_APPOINTMENTS_ID=1e272568-b32a-8010-8f94-f8bb521eeca4
NOTION_DB_LOW_SESSIONS_ID=1865bdbb-e2fa-4997-98d1-fc00d6382649
NOTION_DB_ALL_CLIENTS_ID=846de93c-8cce-4707-a71f-ac5a9fcef37f
NOTION_DB_SESSION_LOGS_ID=1e272568-b32a-805b-8fa1-f4c08fc13a9e
NOTION_DB_CLIENT_INTAKE_FORM_ID=1e272568-b32a-8062-a9a6-f8a71dfd0efa
NOTION_DB_FITCLINIC_CUSTOMER_SYNC_ID=98777021-5044-4456-ae36-d90b1ba7ae1c
NOTION_DB_SQUARE_CUSTOMERS_TFC_ID=d0da27b5-84f7-45b1-ac34-ba2c6f11940d
NOTION_DB_SQUARE_ORDERS_TFC_ID=2d13f6b4-608b-4e35-9e99-8e28f37ab27e
