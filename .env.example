# Square-Notion Sync Configuration
# ==================================
# Copy this file to .env and fill in your credentials.
# DO NOT commit .env to git!

# ─────────────────────────────────────────────────────────────
# SQUARE ACCOUNTS
# ─────────────────────────────────────────────────────────────
# Environment: sandbox or production
SQUARE_ENV=production

# API Version
SQUARE_API_VERSION=2025-06-16

# Physiques Anonymous (Primary Account)
SQUARE_PA_ACCESS_TOKEN=your_pa_access_token_here
SQUARE_PA_LOCATION_ID=your_pa_location_id

# The Fit Clinic LLC
SQUARE_TFC_ACCESS_TOKEN=your_tfc_access_token_here
SQUARE_TFC_LOCATION_ID=your_tfc_location_id

# Fitness With Mike (Legacy)
SQUARE_FWM_ACCESS_TOKEN=your_fwm_access_token_here
SQUARE_FWM_LOCATION_ID=your_fwm_location_id

# ─────────────────────────────────────────────────────────────
# NOTION
# ─────────────────────────────────────────────────────────────
NOTION_TOKEN=your_notion_token_here
NOTION_VERSION=2022-06-28

# Database IDs (from your Notion URLs)
# Client Tracker main database
NOTION_DB_CLIENTS=2cd72568b32a81e58320f515603f19d8

# Transactions/Payments database
NOTION_DB_TRANSACTIONS=2cd72568b32a812387a1fbbbaa9ebd71

# Invoices database (if separate)
NOTION_DB_INVOICES=

# Appointments database (if separate)
NOTION_DB_APPOINTMENTS=

# Session tracking database (can be same as clients)
NOTION_DB_SESSIONS=2cd72568b32a81e58320f515603f19d8

# ─────────────────────────────────────────────────────────────
# SYNC CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Timezone for scheduling
SYNC_TIMEZONE=America/New_York

# Daily sync time (24-hour format)
SYNC_SCHEDULE_HOUR=2
SYNC_SCHEDULE_MINUTE=0

# Session tracking - name of the item to count as sessions
SESSION_ITEM_NAME=One-on-One 60

# ─────────────────────────────────────────────────────────────
# STRIPE (for payments and subscriptions)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_1_SESSION=price_xxx
STRIPE_PRICE_5_SESSIONS=price_xxx
STRIPE_PRICE_10_SESSIONS=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx

# ─────────────────────────────────────────────────────────────
# DATABASE (Neon Postgres)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─────────────────────────────────────────────────────────────
# OPTIONAL: OAuth (for connecting new accounts)
# ─────────────────────────────────────────────────────────────
# SQUARE_APPLICATION_ID=your_app_id
# SQUARE_APPLICATION_SECRET=your_app_secret
# SQUARE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback

# ─────────────────────────────────────────────────────────────
# API AUTHENTICATION
# ─────────────────────────────────────────────────────────────
# Secret key for admin endpoints (sync, scheduler, config, reports).
# When set, requests must include X-Api-Key header with this value.
# When empty/unset, admin endpoints are open (dev mode only!).
API_SECRET_KEY=change-me-to-a-random-secret

# ─────────────────────────────────────────────────────────────
# DEVELOPMENT
# ─────────────────────────────────────────────────────────────
# Set to true to prevent actual API calls
DRY_RUN=false

# Logging level
LOG_LEVEL=INFO
