# Copy this file to .env and fill in your credentials. DO NOT commit secrets.

# Choose 'sandbox' for testing or 'production' for live calls
SQUARE_ENV=sandbox

# Sandbox token (example placeholder)
SQUARE_SANDBOX_ACCESS_TOKEN=replace_with_sandbox_token

# Production token (live) - do not set while testing
SQUARE_ACCESS_TOKEN=replace_with_production_token

# Perplexity API key (if required by your Perplexity installation)
PERPLEXITY_API_KEY=replace_with_perplexity_api_key

# Comet ML API key (for experiment logging)
COMET_API_KEY=replace_with_comet_api_key

# Optional: set to 'true' to actually POST payments; by default sample code will not create real payments
DRY_RUN=true
